classDiagram
    class Owner {
        +String owner_id
        +String name
        +String email
        +String phone
        +List~String~ availability
        +List~Pet~ pets
        +add_pet(pet) void
        +remove_pet(pet_id) void
    }

    class Pet {
        +String pet_id
        +String name
        +String species
        +String breed
        +int age
        +Optional~Owner~ owner
        +Optional~Scheduler~ schedule
        +List~Task~ tasks
        +add_task(task) void
        +get_schedule() Optional~Scheduler~
    }

    class Task {
        +String task_id
        +String title
        +String description
        +String due_date
        +String status
        +int duration_minutes
        +String priority
        +Optional~String~ preferred_time
        +Optional~Scheduler~ scheduler
        +Optional~Pet~ pet
        +int recurring_interval_days
        +complete() void
        +mark_complete() void
        +create_next_occurrence() Optional~Task~
        +reschedule(new_date) void
        +sort_key() Tuple
        +_time_to_minutes(time_value) int
    }

    class Scheduler {
        +String schedule_id
        +Owner owner
        +Pet pet
        +String start_date
        +String end_date
        +List~Task~ tasks
        +generate() void
        +add_task(task) void
        +complete_task(task) void
        +remove_task(task_id) void
        +filter_tasks(pet, status) List~Task~
        +filter_tasks_by_status_or_pet(status, pet_name) List~Task~
        +detect_conflicts() List~Tuple~
        +get_conflict_warning() Optional~String~
        +sort_tasks(tasks) List~Task~
    }

    Owner "1" --> "0..*" Pet : manages
    Pet "0..1" --> "0..1" Scheduler : assigned_to
    Scheduler "1" --> "0..*" Task : contains
    Pet "1" --> "0..*" Task : has
    Task "0..1" --> "0..1" Pet : belongs_to
    Task "0..1" --> "0..1" Scheduler : attached_to
